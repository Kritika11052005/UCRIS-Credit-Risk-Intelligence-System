generator client {
  provider = "prisma-client-py"
  output   = "../app/generated/prisma"
  recursive_type_depth = -1
  enable_experimental_decimal = true
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  hashed_password String
  name            String
  role            String         @default("analyst")
  is_active       Boolean        @default(true)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  refresh_tokens  RefreshToken[]
  customers       Customer[]
  predictions     Prediction[]
  audit_logs      AuditLog[]
  conversations   Conversation[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  is_revoked Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("refresh_tokens")
}

model Customer {
  id           String           @id @default(uuid())
  customer_ref String           @unique
  limit_bal    Int
  sex          Int
  education    Int
  marriage     Int
  age          Int
  created_by   String
  created_at   DateTime         @default(now())
  creator      User             @relation(fields: [created_by], references: [id])
  features     CustomerFeature?
  predictions  Prediction[]

  @@map("customers")
}

model CustomerFeature {
  id                   String   @id @default(uuid())
  customer_id          String   @unique
  avg_utilization      Float
  util_change          Float
  pay_delay_trend      Float
  avg_pay_delay        Float
  consecutive_delays   Int
  avg_repay_ratio      Float
  spending_volatility  Float
  pay_amt_trend        Float
  computed_at          DateTime @default(now())
  customer             Customer @relation(fields: [customer_id], references: [id])

  @@map("customer_features")
}

model Prediction {
  id                 String   @id @default(uuid())
  customer_id        String
  requested_by       String
  stress_level       Int
  stress_label       String
  stress_prob_low    Float
  stress_prob_med    Float
  stress_prob_high   Float
  escalation_flag    Int
  escalation_prob    Float
  recommended_action String
  confidence         String
  shap_factors       Json
  gemini_narrative   String?
  model_version      String
  predicted_at       DateTime @default(now())
  customer           Customer @relation(fields: [customer_id], references: [id])
  requester          User     @relation(fields: [requested_by], references: [id])

  @@map("predictions")
}

model ModelRegistry {
  id               String   @id @default(uuid())
  model_name       String
  version          String
  task             String
  primary_metric   Float
  combined_score   Float
  is_active        Boolean  @default(false)
  registered_at    DateTime @default(now())

  @@map("model_registry")
}

model AuditLog {
  id            String   @id @default(uuid())
  user_id       String
  action        String
  resource_id   String?
  resource_type String?
  payload       Json?
  ip_address    String?
  created_at    DateTime @default(now())
  user          User     @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model Conversation {
  id           String    @id @default(uuid())
  user_id      String
  title        String
  last_message String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  messages     Message[]
  user         User      @relation(fields: [user_id], references: [id])

  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid())
  conversation_id String
  role            String       // "user" or "assistant"
  content         String
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id])

  @@map("messages")
}